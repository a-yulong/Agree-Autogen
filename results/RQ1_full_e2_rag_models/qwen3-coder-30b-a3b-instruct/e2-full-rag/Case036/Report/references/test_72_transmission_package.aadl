package Transmission
public
    with Base_Types;

    data real extends Base_Types::Float
    end real;

    data int extends Base_Types::Integer
    end int;

    data bool extends Base_Types::Boolean
    end bool;

    data speed extends Base_Types::Float
    end speed;

    data state_sig
    end state_sig;

    data implementation state_sig.impl
    end state_sig.impl;

    system Speed_Control
        features
            Target: in data port speed;
            Actuator_Input: out data port real;
            Actual: in data port speed;

        annex agree {**
            const P : real = 1.0;
            const D : real = 0.0;
            const I : real = 0.0;

            eq e : real = Target - Actual;
            eq e_dot : real = 0.0 -> e - pre(e);
            eq e_int : real = 0.0 -> pre(e_int) + e;

            guarantee "PID control law holds":
                Actuator_Input = P * e + D * e_dot + I * e_int;
        **};
    end Speed_Control;

    system implementation Speed_Control.Speed_Control_Impl
        annex agree {**
            -- 实现层无额外子组件，通过系统级保证传递逻辑
        **};
    end Speed_Control.Speed_Control_Impl;

    system Throttle
        features
            Actuator_Input: in data port real;
            Actual: out data port speed;
    end Throttle;

    system implementation Throttle.Throttle_Impl
    end Throttle.Throttle_Impl;

    system State_Machine
        features
            State_Out: out data port state_sig.impl;
    end State_Machine;

    system implementation State_Machine.Impl
        subcomponents
            SSM: system Sub_State_Machine.Impl;

        connections
            SMToSSM: port SSM.State_Out -> State_Out {Communication_Properties::Timing => immediate;};
    end State_Machine.Impl;

    system Sub_State_Machine
        features
            State_Out: out data port state_sig.impl;
    end Sub_State_Machine;

    system implementation Sub_State_Machine.Impl
    end Sub_State_Machine.Impl;

end Transmission;
