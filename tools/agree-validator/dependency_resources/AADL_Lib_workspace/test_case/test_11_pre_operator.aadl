package TestPreOperator
public
	with Base_Types;

	data int extends Base_Types::Integer
	end int;

	data real extends Base_Types::Float
	end real;

	data bool extends Base_Types::Boolean
	end bool;

	system TestSystem
		features
			input1: in data port int;
			output1: out data port int;
		annex agree {**
			-- 错误11：pre语句没有和()搭配
			eq t : real = 0.0 -> pre t + 1.0;
			eq x : int = pre(input1);
		**};
	end TestSystem;

end TestPreOperator;
