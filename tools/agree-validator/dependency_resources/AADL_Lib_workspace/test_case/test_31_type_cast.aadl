package TestTypeCast
public
    with Base_Types;

    data int extends Base_Types::Integer
    end int;

    data real extends Base_Types::Float
    end real;

    data bool extends Base_Types::Boolean
    end bool;

    system TestSystem
        features
            int_input: in data port int;
            real_input: in data port real;
            output1: out data port int;
        annex agree {**
            -- 错误31：类型转换错误
            eq x : int = (int) true;           -- bool转int
            eq y : real = (real) "3.14";       -- 字符串转real
            eq z : bool = (bool) 5;            -- int转bool

            -- 隐式类型转换问题
            eq mixed : int = int_input + real_input;  -- 混合类型运算
        **};
    end TestSystem;

end TestTypeCast;
