package TestArrayOperations
public
    with Base_Types;

    data int extends Base_Types::Integer
    end int;

    data real extends Base_Types::Float
    end real;

    data bool extends Base_Types::Boolean
    end bool;

    -- 数组类型定义
    data int_array extends Base_Types::Integer[]
    end int_array;

    system TestSystem
        features
            arr: in data port int_array;
            idx: in data port int;
            output1: out data port int;
        annex agree {**
            -- 错误25：数组操作错误
            eq x : int = arr[true];           -- 索引必须是整数
            eq y : int = arr["index"];        -- 索引必须是整数
            eq z : bool = arr[0];             -- 数组元素类型不匹配

            -- 数组字面量（如果支持）
            eq my_arr : int_array = [1, 2, 3, true];  -- 元素类型不一致
        **};
    end TestSystem;

end TestArrayOperations;
