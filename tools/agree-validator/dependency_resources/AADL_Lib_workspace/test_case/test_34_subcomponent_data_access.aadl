package TestSubcomponentDataAccess
public
    with Base_Types;

    data int extends Base_Types::Integer
    end int;

    data real extends Base_Types::Float
    end real;

    data bool extends Base_Types::Boolean
    end bool;

    -- 子系统定义
    system SubSystem
        features
            sub_in: in data port int;
            sub_out: out data port int;
    end SubSystem;

    system implementation SubSystem.impl
        annex agree {**
            eq internal : int = sub_in + 5;
            assign sub_out = internal;
        **};
    end SubSystem.impl;

    -- 主系统
    system TestSystem
        features
            main_in: in data port int;
            main_out: out data port int;
        annex agree {**
            -- 错误34a：在component type中访问子组件内部变量（还没有子组件）
            guarantee "bad_access": SubSystem.internal > 0;
        **};
    end TestSystem;

    system implementation TestSystem.impl
        subcomponents
            sub: system SubSystem.impl;
        annex agree {**
            -- 错误34b：访问子组件的内部eq变量
            eq x : int = sub.internal;  -- 内部变量不可访问

            -- 正确：访问子组件的端口
            assign main_out = sub.sub_out;
        **};
    end TestSystem.impl;

end TestSubcomponentDataAccess;
