package TestWithPackageReferences
public
    -- 修复记录#15, #16场景：各种标包引用
    with Base_Types;
    with Agree_Nodes;
    with composite_nodes;
    with gcas_nodes;
    with geofence_nodes;
    with tcas_nodes;

    data int extends Base_Types::Integer
    end int;

    data real extends Base_Types::Float
    end real;

    data bool extends Base_Types::Boolean
    end bool;

    system TestSystem
        features
            input: in data port int;
            output: out data port bool;
        annex agree {**
         
            -- 使用tcas_nodes中的节点
            eq abs_diff : int = tcas_nodes::abs_diff(input, 5);

            
           

            -- 保证语句
            guarantee "result_implies": output => input > 0;
        **};
    end TestSystem;

end TestWithPackageReferences;
