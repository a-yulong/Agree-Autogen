package TestMissingWith
public

	-- 错误3：缺少with引用但使用了Base_Types
	data int extends Base_Types::Integer
	end int;

	data real extends Base_Types::Float
	end real;

	data bool extends Base_Types::Boolean
	end bool;

	system TestSystem
		features
			input1: in data port int;
			output1: out data port int;
		annex agree {**
			eq x : int = 0;
			guarantee "test": x >= 0;
		**};
	end TestSystem;

end TestMissingWith;
