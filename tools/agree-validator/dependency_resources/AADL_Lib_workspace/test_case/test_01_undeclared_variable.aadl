package TestVariableDeclaration
public
	with Base_Types;

	data int extends Base_Types::Integer
	end int;

	data real extends Base_Types::Float
	end real;

	data bool extends Base_Types::Boolean
	end bool;

	system TestSystem
		features
			input1: in data port int;
			output1: out data port int;
		annex agree {**
			-- 错误1：未通过eq声明变量就直接使用
			eq danger : (input1 > 10);
		**};
	end TestSystem;

end TestVariableDeclaration;
