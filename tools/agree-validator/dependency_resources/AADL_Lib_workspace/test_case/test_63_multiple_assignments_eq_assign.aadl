package TestMultipleAssignmentsEqAssign
public
    with Base_Types;

    data int extends Base_Types::Integer
    end int;

    data real extends Base_Types::Float
    end real;

    data bool extends Base_Types::Boolean
    end bool;

    -- 修复记录#12场景：eq在type中有表达式，assign在impl中 - 应该报多次赋值错误
    system TestSystem
        features
            input: in data port int;
            output: out data port real;
        annex agree {**
            -- eq在type中，有表达式 - 这算是赋值
            eq t : real = 0.0 -> pre(t) + 1.0;

            -- eq在type中，只有声明 - 这不算赋值
            eq x : int;
        **};
    end TestSystem;

    system implementation TestSystem.impl
        annex agree {**
            -- assign t - 这应该与type中的eq t冲突
            assign t = 0.0 -> pre(t) + 1.0;

            -- assign x - 这应该没问题，因为type中的eq x只有声明
            assign x = input + 5;

            assign output = t;
        **};
    end TestSystem.impl;

end TestMultipleAssignmentsEqAssign;
