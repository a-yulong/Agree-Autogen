package TestAssignmentOperator
public
	with Base_Types;

	data int extends Base_Types::Integer
	end int;

	data real extends Base_Types::Float
	end real;

	data bool extends Base_Types::Boolean
	end bool;

	system TestSystem
		features
			input1: in data port int;
			output1: out data port int;
		annex agree {**
			-- 错误9：使用了:=而不是=
			eq x : int := 0;
		**};
	end TestSystem;

end TestAssignmentOperator;
