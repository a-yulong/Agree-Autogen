package TestCompoundGuarantees
public
    with Base_Types;

    data int extends Base_Types::Integer
    end int;

    data real extends Base_Types::Float
    end real;

    data bool extends Base_Types::Boolean
    end bool;

    system TestSystem
        features
            speed: in data port real;
            brake: in data port bool;
            output1: out data port real;
        annex agree {**
            eq accel : real = if brake then -10.0 else (speed < 100.0 ? 5.0 : 0.0);
            eq new_speed : real = 0.0 -> pre(new_speed) + accel * 0.1;

            -- 错误46：复杂的保证条件
            assume "speed_bounds": speed >= 0.0 and speed < 200.0;

            -- 蕴含保证
            guarantee "brake_slows_down": brake => new_speed < pre(new_speed);

            -- 时间操作符保证
            guarantee "eventually_stop": brake => F(new_speed = 0.0);
            guarantee "always_safe": G(new_speed >= 0.0);

            -- 复杂的布尔组合
            guarantee "complex": (speed > 50.0 and not brake) => X(new_speed > speed);

            -- 错误的保证类型
            guarantee "bad_type": new_speed;  -- 不是bool表达式
            guarantee "bad_var": undefined_var > 0;  -- 未定义变量
            guarantee "type_mismatch": speed = true;  -- 类型不匹配
        **};
    end TestSystem;

end TestCompoundGuarantees;
