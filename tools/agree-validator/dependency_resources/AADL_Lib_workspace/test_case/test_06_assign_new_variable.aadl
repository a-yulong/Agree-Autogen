package TestAssignNewVariable
public
	with Base_Types;

	data int extends Base_Types::Integer
	end int;

	data real extends Base_Types::Float
	end real;

	data bool extends Base_Types::Boolean
	end bool;

	system TestSystem
		features
			input1: in data port int;
			output1: out data port int;
		annex agree {**
			eq x : int = 0;
		**};
	end TestSystem;

	system implementation TestSystem.Impl
		annex agree {**
			-- 错误6：assign不能创建新变量
			assign newVar = input1;
			assign output1 = newVar;
		**};
	end TestSystem.Impl;

end TestAssignNewVariable;
