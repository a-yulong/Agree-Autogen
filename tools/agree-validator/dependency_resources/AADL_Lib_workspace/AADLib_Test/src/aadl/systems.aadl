--  This package models several root systems, each of which defines a
--  set of architecture-level properties to be verified using REAL

package Systems
public

  -----------------
  -- AADL_System --
  -----------------

  --  This system drags all advanced AADL legality rules not checked
  --  by Ocarina.

  system AADL_System
  end AADL_System;

