# OpenAI-compatible model endpoint
AGREE_MODEL_BASE_URL=https://api.openai.com/v1
AGREE_MODEL_API_KEY=replace-with-your-key
AGREE_MODEL_NAME=gpt-4o-mini

# Optional: use a separate model for error type classification
AGREE_ERROR_ANALYZER_BASE_URL=${AGREE_MODEL_BASE_URL}
AGREE_ERROR_ANALYZER_API_KEY=${AGREE_MODEL_API_KEY}
AGREE_ERROR_ANALYZER_MODEL=${AGREE_MODEL_NAME}

# Local data and outputs
AGREE_DATA_ROOT=./data
AGREE_SOURCE_ROOT=./data/Sources
AGREE_RESULT_ROOT=./results
AGREE_DOCS_DIR=./docs/AGREE_Users_Guide
AGREE_WORK_MODEL=./modified_model.aadl

# External validators
AADL_INSPECTOR_PATH=AADLInspector.exe
OSATE_HOME=/path/to/osate
JAVA_HOME=/path/to/jdk17
AGREE_VALIDATOR_ROOT=./tools/agree-validator
